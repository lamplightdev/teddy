{
	"compilerOptions": {
		"allowJs": true,
		"checkJs": true,
		"noEmit": true,
		"strict": true,
		"skipLibCheck": true,
		"noImplicitAny": true,
		"strictNullChecks": true,

		"target": "esnext",
		"module": "nodenext",
		"moduleResolution": "nodenext",

		"lib": ["dom", "dom.iterable", "esnext"]
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules"]
}
